.companion-view-button {
    background-image: url("project://database/Assets/Sprites/UI/CombatScreen_HoverButton.png?fileID=2800000&guid=5a7e6950ede86cb47811b1d9e1947916&type=3#CombatScreen_HoverButton");
}

#companion-view-draw-pile:hover {
    scale: 1.25 1.25;
}

#companion-view-discard-pile:hover {
    scale: 1.25 1.25;
}

.pile-no-cards {
    background-image: url("project://database/Assets/Sprites/UI/TempDeckIcons/deck_sprite_5.png?fileID=2800000&guid=8505e242378736b44aecbb7ff1429a64&type=3#deck_sprite_5");
    -unity-background-image-tint-color: rgba(255, 255, 255, 0.65);
}

.pile-one-card {
    background-image: url("project://database/Assets/Sprites/UI/TempDeckIcons/deck_sprite_1.png?fileID=2800000&guid=c6cc2924e39911c46878fa6a0efa547f&type=3#deck_sprite_1");
}

.pile-two-cards {
    background-image: url("project://database/Assets/Sprites/UI/TempDeckIcons/deck_sprite_2.png?fileID=2800000&guid=ad95741a0431b6f48bfc5ab74bc1a586&type=3#deck_sprite_2");
}

.pile-three-cards {
    background-image: url("project://database/Assets/Sprites/UI/TempDeckIcons/deck_sprite_3.png?fileID=2800000&guid=41802ee98cf4fb847b3ebb08ec2483ed&type=3#deck_sprite_3");
}

.pile-four-plus-cards {
    background-image: url("project://database/Assets/Sprites/UI/TempDeckIcons/deck_sprite_4.png?fileID=2800000&guid=ec2fcfa1ee4e3ac41bdc24b623317e4f&type=3#deck_sprite_4");
}

.companion-view-deck-shuffled-card {
    -unity-background-scale-mode: scale-to-fit;
    background-image: url("project://database/Assets/Sprites/UI/TempDeckIcons/deck_sprite_1.png?fileID=2800000&guid=c6cc2924e39911c46878fa6a0efa547f&type=3#deck_sprite_1");
    position: absolute;
}
